# ─── Database (Supabase / Neon / Railway) ───────────────────────────────────
# Get this from your Supabase project:
#   Settings → Database → Connection string → URI
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Same as DATABASE_URL for Supabase. If using Neon, use the non-pooled URL here.
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# ─── Redis (Upstash) ─────────────────────────────────────────────────────────
# Get this from your Upstash dashboard → Redis → Connect → ioredis
REDIS_URL="redis://default:[PASSWORD]@[HOST].upstash.io:6379"

# ─── Cron protection (optional) ──────────────────────────────────────────────
# Set a random secret and add it to Vercel too
CRON_SECRET="change-me-to-a-random-string"
